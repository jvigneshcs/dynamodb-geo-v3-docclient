{
  "compilerOptions": {
    /* Core Settings */
    "target": "es2024",
    "module": "NodeNext", 
    "moduleResolution": "NodeNext",
    "lib": ["es2024"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "./src",
    
    /* Strictness & Safety */
    "strict": true, 
    "noImplicitAny": true, 
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Bundling & Lambda Optimization */
    "sourceMap": true, 
    "declaration": true,
    "removeComments": true
  },
  "include": ["src/**/*"]
}