{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2024",
    "noImplicitAny": false,
    "sourceMap": false,
    "rootDir": "./src",
    "outDir": "dist",
    "lib": ["es2024"],
    "types": ["node"],
    "esModuleInterop": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
